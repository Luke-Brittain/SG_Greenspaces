556c-bf19-40ca-fffb-b8243a2d0979"},"source":["raster_features_3d = np.array([b2, b3, b4, b8, b11, b12, ndvi_raster])\n","\n","# Transpose the array to have the channels (features) as the last dimension\n","# Original shape: (num_features, height, width)\n","# Desired intermediate shape: (height, width, num_features)\n","raster_features_3d = np.transpose(raster_features_3d, (1, 2, 0))\n","\n","# Reshape the 3D array into a 2D array (height * width, num_features)\n","raster_features_reshaped = raster_features_3d.reshape(-1, raster_features_3d.shape[-1])\n","\n","print(f\"Original raster data shape (individual band): {b2.shape}\")\n","print(f\"Concatenated 3D raster features shape: {raster_features_3d.shape}\")\n","print(f\"Reshaped 2D raster features shape: {raster_features_reshaped.shape}\")\n","\n","raster_features_reshaped_cleaned = np.nan_to_num(raster_features_reshaped, nan=0.0, posinf=0.0, neginf=0.0)\n","\n","# Suppress the UserWarning from scikit-learn about feature names\n","import warnings\n","with warnings.catch_warnings():\n","    warnings.simplefilter(\"ignore\", UserWarning)\n","    raster_features_scaled = scaler.transform(raster_features_reshaped_cleaned)\n","\n","print(f\"Shape of scaled raster features: {raster_features_scaled.shape}\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Original raster data shape (individual band): (3897, 6123)\n","Concatenated 3D raster features shape: (3897, 6123, 7)\n","Reshaped 2D raster features shape: (23861331, 7)\n","Shape of scaled raster features: (23861331, 7)\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"a1c13148","executionInfo":{"status":"ok","timestamp":1771499553435,"user_tz":-480,"elapsed":89640,"user":{"displayName":"Luke Brittain","userId":"00221678302953275086"}},"outputId":"d605a479-58b9-4221-cebb-01470c4e0039"},"source":["raster_predictions = best_xgb_model.predict(raster_features_scaled)\n","\n","print(f\"Shape of r